{
  "datasets": [
    {
      "name": "11111111",
      "displayName": "ds_kpi",
      "queryLines": [
        "WITH filtered AS (\n",
        "  SELECT *\n",
        "  FROM lakehouse_demo.gold.agg_sales_monthly\n",
        "  WHERE (size(:param_year)  = 0 OR array_contains(:param_year, year))\n",
        "    AND (size(:param_month) = 0 OR array_contains(:param_month, month))\n",
        "),\n",
        "monthly AS (\n",
        "  SELECT year_month,\n",
        "         SUM(total_revenue)                              AS revenue,\n",
        "         SUM(orders)                                     AS orders,\n",
        "         SUM(unique_customers)                           AS unique_customers,\n",
        "         SUM(total_revenue) / NULLIF(SUM(orders), 0)     AS aov\n",
        "  FROM filtered\n",
        "  GROUP BY year_month\n",
        ")\n",
        "SELECT\n",
        "  ROUND(SUM(revenue), 2)                                                     AS total_revenue,\n",
        "  SUM(orders)                                                                AS total_orders,\n",
        "  ROUND(SUM(revenue) / NULLIF(SUM(orders), 0), 2)                            AS aov,\n",
        "  SUM(unique_customers)                                                      AS unique_customers\n",
        "FROM monthly\n"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "param_year",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        },
        {
          "displayName": "Month",
          "keyword": "param_month",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        }
      ]
    },
    {
      "name": "22222222",
      "displayName": "ds_trend",
      "queryLines": [
        "SELECT\n",
        "  year_month,\n",
        "  loyalty_segment,\n",
        "  ROUND(SUM(total_revenue), 2)                                               AS revenue\n",
        "FROM lakehouse_demo.gold.agg_sales_monthly\n",
        "WHERE loyalty_segment IS NOT NULL\n",
        "  AND (size(:param_year)  = 0 OR array_contains(:param_year, year))\n",
        "  AND (size(:param_month) = 0 OR array_contains(:param_month, month))\n",
        "GROUP BY year_month, loyalty_segment\n",
        "ORDER BY year_month, loyalty_segment\n"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "param_year",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        },
        {
          "displayName": "Month",
          "keyword": "param_month",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        }
      ]
    },
    {
      "name": "33333333",
      "displayName": "ds_heatmap",
      "queryLines": [
        "SELECT\n",
        "  product_category,\n",
        "  state,\n",
        "  ROUND(SUM(total_revenue), 2)                                               AS revenue\n",
        "FROM lakehouse_demo.gold.agg_sales_monthly\n",
        "WHERE product_category IS NOT NULL\n",
        "  AND state IS NOT NULL\n",
        "  AND (size(:param_year)  = 0 OR array_contains(:param_year, year))\n",
        "  AND (size(:param_month) = 0 OR array_contains(:param_month, month))\n",
        "GROUP BY product_category, state\n"
      ],
      "parameters": [
        {
          "displayName": "Year",
          "keyword": "param_year",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        },
        {
          "displayName": "Month",
          "keyword": "param_month",
          "dataType": "INTEGER",
          "complexType": "MULTI",
          "defaultSelection": {
            "values": {
              "dataType": "INTEGER"
            }
          }
        }
      ]
    },
    {
      "name": "44444444",
      "displayName": "ds_year_param",
      "queryLines": [
        "SELECT DISTINCT year\n",
        "FROM lakehouse_demo.gold.agg_sales_monthly\n",
        "WHERE year IS NOT NULL\n",
        "ORDER BY year\n"
      ]
    },
    {
      "name": "55555555",
      "displayName": "ds_month_param",
      "queryLines": [
        "SELECT DISTINCT month\n",
        "FROM lakehouse_demo.gold.agg_sales_monthly\n",
        "WHERE month IS NOT NULL\n",
        "ORDER BY month\n"
      ]
    }
  ],
